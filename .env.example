# Copy to .env and fill in values before running `make dev`

# Host ports — change if a port is already in use on your machine.
# The internal container ports never change; only the host-side binding does.
# macOS note: port 5000 is taken by AirPlay Receiver — use 5001 for MLFLOW_PORT.
API_PORT=8000
MLFLOW_PORT=5000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Model URIs are optional until models are trained and registered (Phase 2+).
# Leave empty to start the stack without model inference support.
FRAUD_MODEL_URI=
SENTIMENT_MODEL_URI=
FORECAST_MODEL_URI=
